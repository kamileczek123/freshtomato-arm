# Wireless settings for: (wl0) / 2.4 GHz
nvram set wl0_afterburner='{{ wl0_afterburner }}'
nvram set wl0_btc_mode='{{ wl0_btc_mode }}'
nvram set wl0_frameburst='{{ wl0_frameburst }}'

nvram set wl0_country_code='{{ wl0_country_code }}'
nvram set wl0_country_rev='{{ wl0_country_rev }}'
nvram set wl0_reg_mode='{{ wl0_reg_mode }}'
nvram set wl0_txpwr='{{ wl0_txpwr }}'
## R8000
nvram set 1:maxp2ga0='{{ r8000_1_maxp2ga0 }}'
nvram set 1:maxp2ga1='{{ r8000_1_maxp2ga1 }}'
nvram set 1:maxp2ga2='{{ r8000_1_maxp2ga2 }}'
nvram set 1:ccode='{{ wl0_country_code }}'
nvram set 1:regrev='{{ wl0_country_rev }}'
## R7000
nvram set pci/1/1/maxp2ga0='{{ r7000_pci_1_1_maxp2ga0 }}'
nvram set pci/1/1/maxp2ga1='{{ r7000_pci_1_1_maxp2ga1 }}'
nvram set pci/1/1/maxp2ga2='{{ r7000_pci_1_1_maxp2ga2 }}'
nvram set pci/1/1/ccode='{{ wl0_country_code }}'
nvram set pci/1/1/regrev='{{ wl0_country_code }}'



